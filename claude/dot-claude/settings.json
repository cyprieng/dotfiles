{
  "permissions": {
    "allow": [
      "Bash(command:rg *)",
      "Bash(command:fd *)",
      "Bash(command:find *)",
      "Bash(command:ls *)",
      "Bash(command:cat *)",
      "Bash(command:head *)",
      "Bash(command:tail *)",
      "Bash(command:wc *)",
      "Bash(command:jq *)",
      "Bash(command:git status*)",
      "Bash(command:git log*)",
      "Bash(command:git diff*)",
      "Bash(command:diff *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  }
}
