{
  "permissions": {
    "allow": [
      "Bash(command:rg *)",
      "Bash(command:fd *)",
      "Bash(command:find *)",
      "Bash(command:ls *)",
      "Bash(command:cat *)",
      "Bash(command:head *)",
      "Bash(command:tail *)",
      "Bash(command:wc *)",
      "Bash(command:jq *)",
      "Bash(command:git status*)",
      "Bash(command:git log*)",
      "Bash(command:git diff*)",
      "Bash(command:diff *)",
      "Bash(gh pr view:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(grep:*)",
      "Bash(tee:*)",
      "Bash(nvr *)",
      "mcp__plugin_claude-mem_mcp-search__*"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  }
}
