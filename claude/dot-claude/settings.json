{
  "permissions": {
    "allow": [
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(diff:*)",
      "Bash(gh pr view:*)",
      "Bash(grep:*)",
      "Bash(tee:*)",
      "Bash(nvr:*)",
      "Bash(rtk rg:*)",
      "Bash(rtk fd:*)",
      "Bash(rtk find:*)",
      "Bash(rtk ls:*)",
      "Bash(rtk cat:*)",
      "Bash(rtk head:*)",
      "Bash(rtk tail:*)",
      "Bash(rtk wc:*)",
      "Bash(rtk jq:*)",
      "Bash(rtk git status:*)",
      "Bash(rtk git log:*)",
      "Bash(rtk git diff:*)",
      "Bash(rtk git show:*)",
      "Bash(rtk diff:*)",
      "Bash(rtk gh pr view:*)",
      "Bash(rtk grep:*)",
      "Bash(rtk tee:*)",
      "Bash(rtk nvr:*)",
      "mcp__plugin_claude-mem_mcp-search__*"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  }
}